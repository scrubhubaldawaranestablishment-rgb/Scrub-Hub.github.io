# Database
DATABASE_URL="postgresql://creatorpilot:creatorpilot@localhost:5432/creatorpilot?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# API
API_PORT=4000
JWT_SECRET="change-me-in-production-use-long-random-string"
JWT_EXPIRES_IN="7d"
CORS_ORIGIN="http://localhost:3000,http://127.0.0.1:3000"

# Next.js proxy target for /api rewrites (server-side only)
API_PROXY_TARGET="http://localhost:4000"

# OpenAI
OPENAI_API_KEY="sk-your-openai-key"
OPENAI_MODEL="gpt-4o-mini"

# YouTube
YOUTUBE_API_KEY="your-youtube-api-key"
YOUTUBE_CLIENT_ID=""
YOUTUBE_CLIENT_SECRET=""
YOUTUBE_REDIRECT_URI="http://localhost:4000/api/integrations/youtube/callback"

# TikTok
TIKTOK_CLIENT_KEY=""
TIKTOK_CLIENT_SECRET=""
TIKTOK_REDIRECT_URI="http://localhost:4000/api/integrations/tiktok/callback"

# Next.js (browser uses same-origin /api proxy by default)
NEXT_PUBLIC_API_URL="/api"
NEXTAUTH_SECRET="change-me-in-production"
NEXTAUTH_URL="http://localhost:3000"
