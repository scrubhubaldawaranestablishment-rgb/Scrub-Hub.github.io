# NOSSCO Nexxus — Base44 → Google Drive backup
# Copy to .env in this folder or export before running backup_documents.py

# Base44 (required)
BASE44_API_TOKEN=your-base44-api-token
BASE44_APP_ID=6a1ae5a11195cab07d9a51af
BASE44_ENTITY=ComplianceDocument
BASE44_API_BASE=https://base44.app/api/apps

# Google Drive (required for real upload)
# Google Workspace Shared Drive folder (must be inside a Shared Drive)
GOOGLE_DRIVE_FOLDER_ID=1i-t3_wyCRHa8zP0AtLgij61RCYv02kqn

# Full workspace sync (all entities + files)
# python3 scripts/nossco-backup/sync_workspace.py
WORKSPACE_SYNC_ENTITIES=Vendor,Client,ComplianceDocument,VendorApplication,Ticket,ServiceRequest,WorkOrder

# Optional
BACKUP_DRY_RUN=0
BACKUP_MANIFEST=1
BACKUP_CHUNK_SIZE=262144
